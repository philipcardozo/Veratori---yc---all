rules_version = '2';

// Veratori Firestore — Phase B.
//
// All writes come from the Jetson service account (firebase-admin SDK),
// which bypasses these rules. Clients are read-only.
//
// Custom claims (set by Phase C `setUserClaims` Firebase Function):
//   role:       'owner' | 'manager' | 'jetson'
//   franchises: ['<id>', ...]   (managers — array)
//   franchise:  '<id>'          (jetsons — single)
// Manager shape matches role-guard.js#allowedFranchises().
// Jetson shape matches provisionJetson Function output.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null && request.auth.token.role == 'owner';
    }

    function ownsFranchise(franchiseId) {
      return request.auth != null
          && request.auth.token.franchises is list
          && franchiseId in request.auth.token.franchises;
    }

    // True when the caller is a Jetson service identity writing data for
    // the franchise it was provisioned for. Used to scope the firehose of
    // sales + alerts from sync_agent.py so a compromised Jetson can only
    // affect its own franchise.
    function isJetsonFor(franchiseId) {
      return request.auth != null
          && request.auth.token.role == 'jetson'
          && request.auth.token.franchise == franchiseId;
    }

    match /sales/{saleId} {
      allow read:          if isOwner() || ownsFranchise(resource.data.franchise_id);
      // Jetsons may create new sale docs (deterministic doc IDs make
      // retries safe — same row → same doc id → idempotent overwrite via update).
      allow create, update: if isJetsonFor(request.resource.data.franchise_id);
      allow delete:         if false;
    }

    match /alerts/{alertId} {
      allow read:           if isOwner() || ownsFranchise(resource.data.franchise_id);
      // Jetsons may create alerts and patch resolved_at on their own franchise's docs.
      allow create:         if isJetsonFor(request.resource.data.franchise_id);
      allow update:         if isJetsonFor(resource.data.franchise_id)
                            && isJetsonFor(request.resource.data.franchise_id);
      allow delete:         if false;
    }
  }
}
