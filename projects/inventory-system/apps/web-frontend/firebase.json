{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "*.json",
      "**/.*",
      "**/node_modules/**",
      "public/**"
    ],
    "cleanUrls": false,
    "rewrites": [
      { "source": "/login", "destination": "/login.html" }
    ]
  },
  "firestore": {
    "rules":   "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source":   "functions",
      "codebase": "default",
      "runtime":  "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
